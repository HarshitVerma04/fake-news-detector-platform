# Copy this file to .env and fill in your values
# Never commit .env to git

# PostgreSQL
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/fakenews_db

# App
APP_ENV=development

# Model selection: "tfidf" (Phase 2) or "distilbert" (Phase 6)
ACTIVE_MODEL=tfidf

# TF-IDF model paths (Phase 2)
MODEL_PATH=model/saved/tfidf_logreg.joblib
VECTORIZER_PATH=model/saved/tfidf_vectorizer.joblib

# DistilBERT model path (Phase 6 — folder containing config.json and model weights)
DISTILBERT_MODEL_PATH=model/saved/distilbert
